PORT=3000
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# Email (SMTP). Leave SMTP_HOST blank to use an ethereal/test transport in dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Virtual Events <no-reply@virtual-events.local>"
